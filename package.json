{
  "name": "secretssanta",
  "version": "1.0.0",
  "private": true,
  "description": "Consul KV companion extension",
  "scripts": {
    "build": "node scripts/build.mjs --target=chromium",
    "build:chromium": "node scripts/build.mjs --target=chromium",
    "build:firefox": "node scripts/build.mjs --target=firefox",
    "build:all": "node scripts/build.mjs --target=all",
    "zip": "npm run build:chromium && cd dist/chromium && zip -r ../../SecretsSanta-chromium.zip . && npm run build:firefox && cd dist/firefox && zip -r ../../SecretsSanta-firefox.zip ."
  },
  "devDependencies": {
    "esbuild": "^0.19.12"
  }
}
